---
/**
 * Shared shell for Astro status pages (404 missing route, 500 application error).
 * Same full-bleed SiteHeader + site Footer as legal/content pages; the error
 * itself is a centered card (landing terminal treatment).
 */
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import SiteHeader from "../components/SiteHeader.astro";

interface Props {
  status: number;
  title: string;
  message: string;
  /** Optional one-line hint under the message */
  hint?: string;
}

const { status, title, message, hint } = Astro.props;

// Static page — auth origin baked at build time (see LegalLayout / landing).
const authOrigin = import.meta.env.PUBLIC_UPLOADS_AUTH_ORIGIN ?? "https://auth.uploads.sh";
---

<html lang="en">
  <head>
    <BaseHead preloadSans />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <meta name="description" content={`${status} ${title} — uploads.sh`} />
    <title>{status} · {title} · uploads.sh</title>
    <style>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100dvh;
        background: var(--bg);
        color: var(--fg);
        font: 14.5px/1.65 var(--mono);
        display: flex;
        flex-direction: column;
      }
      main {
        flex: 1;
        display: grid;
        place-items: center;
        padding: 28px 24px;
        width: 100%;
      }
      .card-wrap { width: min(var(--width-card, 480px), 100%); }
      .card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: var(--radius-lg);
        overflow: hidden;
      }
      .titlebar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 14px;
        border-bottom: 1px solid var(--line);
        color: var(--muted);
        font-family: var(--pixel);
        font-variation-settings: "ELSH" var(--pixel-shape, 1);
        font-size: 11px;
        letter-spacing: 0.05em;
      }
      .body { padding: 26px 22px 24px; }
      .status {
        margin: 0 0 6px;
        font: 600 clamp(2.2rem, 8vw, 2.8rem)/1.1 var(--sans);
        letter-spacing: -0.015em;
        color: var(--accent);
      }
      h1 {
        margin: 0 0 12px;
        font: 600 1rem/1.4 var(--sans);
        color: var(--fg);
      }
      p {
        margin: 0;
        color: var(--body);
        font: 0.92rem/1.6 var(--sans);
      }
      .hint {
        margin-top: 10px;
        font-size: 0.85rem;
        color: var(--muted);
      }
      .actions {
        margin-top: 22px;
      }
      .home {
        display: inline-block;
        font: 12px var(--mono);
        color: var(--muted);
        background: var(--bg);
        border: 1px solid var(--line);
        border-radius: var(--radius-sm);
        padding: 7px 12px;
        text-decoration: none;
      }
      .home:hover,
      .home:focus-visible {
        color: var(--fg);
        border-color: var(--accent);
        outline: none;
      }
    </style>
  </head>
  <body>
    <SiteHeader authOrigin={authOrigin} />
    <main>
      <div class="card-wrap">
        <section class="card" aria-labelledby="error-title">
          <div class="titlebar" aria-hidden="true">
            <span>uploads.sh — error</span>
            <span>{status}</span>
          </div>
          <div class="body">
            <p class="status" aria-hidden="true">{status}</p>
            <h1 id="error-title">{title}</h1>
            <p>{message}</p>
            {hint ? <p class="hint">{hint}</p> : null}
            <div class="actions">
              <a class="home" href="/">← home</a>
            </div>
          </div>
        </section>
      </div>
    </main>
    {/* Full-bleed shell footer — sibling of main, same as legal/content pages. */}
    <Footer />
  </body>
</html>
