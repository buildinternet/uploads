---
import { fetchPublicGallery, type PublicGalleryItem } from "../../lib/public-gallery";
import { env } from "cloudflare:workers";

export const prerender = false;

const id = Astro.params.id ?? "";
const origin =
  env.UPLOADS_API_ORIGIN ??
  import.meta.env.PUBLIC_UPLOADS_API_ORIGIN ??
  "https://api.uploads.sh";
const result = await fetchPublicGallery(id, { origin });

Astro.response.headers.set("Content-Security-Policy", "default-src 'none'; img-src https: data:; media-src https:; style-src 'unsafe-inline'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'; object-src 'none'");
Astro.response.headers.set("Referrer-Policy", "no-referrer");
Astro.response.headers.set("X-Content-Type-Options", "nosniff");
Astro.response.headers.set("X-Frame-Options", "DENY");
Astro.response.headers.set("X-Robots-Tag", "noindex, nofollow, noarchive");
Astro.response.headers.set("Cross-Origin-Opener-Policy", "same-origin");
Astro.response.headers.set("Permissions-Policy", "camera=(), microphone=(), geolocation=()");
Astro.response.headers.set("Cache-Control", "no-store");
if (result.status === "not_found") Astro.response.status = 404;
if (result.status === "unavailable") Astro.response.status = 503;

const gallery = result.status === "ok" ? result.gallery : null;
const canonical = new URL(`/g/${encodeURIComponent(id)}`, Astro.url.origin).href;
const imageTypes = new Set(["image/png", "image/jpeg", "image/gif", "image/webp", "image/avif"]);
const videoTypes = new Set(["video/mp4", "video/webm"]);
const kind = (item: PublicGalleryItem) => item.status === "missing" ? "missing" : imageTypes.has(item.contentType ?? "") ? "image" : videoTypes.has(item.contentType ?? "") ? "video" : item.contentType === "image/svg+xml" ? "unsupported" : "file";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <link rel="canonical" href={canonical} />
    <title>{gallery ? `${gallery.title} · uploads.sh` : "Gallery unavailable · uploads.sh"}</title>
    <meta name="description" content={gallery?.description ?? "A public media gallery hosted by uploads.sh."} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={gallery?.title ?? "Gallery unavailable"} />
    <meta property="og:description" content={gallery?.description ?? "A public media gallery hosted by uploads.sh."} />
    <meta property="og:url" content={canonical} />
    <style>
      :root { color-scheme: dark; --bg:#0b0813; --panel:#120d1e; --edge:#2b1e46; --fg:#ece6f8; --muted:#9187a8; --purple:#b794ff; --cyan:#7dcfff; --danger:#e0a2b7; --mono:ui-monospace,"SFMono-Regular",Consolas,monospace; --sans:Inter,ui-sans-serif,system-ui,sans-serif; }
      * { box-sizing:border-box; }
      body { margin:0; min-height:100vh; color:var(--fg); background:radial-gradient(70rem 40rem at 50% -12rem,#261641 0%,var(--bg) 62%); font-family:var(--sans); }
      body::before { content:""; position:fixed; inset:0; pointer-events:none; opacity:.18; background:repeating-linear-gradient(to bottom,transparent 0 3px,rgba(255,255,255,.025) 3px 4px); }
      .shell { width:min(1180px,calc(100% - 32px)); margin:auto; padding:38px 0 64px; }
      nav { display:flex; align-items:center; justify-content:space-between; margin-bottom:64px; font:600 13px var(--mono); letter-spacing:.04em; }
      .brand { color:var(--fg); text-decoration:none; } .brand span { color:var(--purple); }
      .public { color:var(--muted); border:1px solid var(--edge); border-radius:999px; padding:7px 11px; }
      header { max-width:820px; margin-bottom:34px; }
      .eyebrow { color:var(--purple); font:600 12px var(--mono); letter-spacing:.14em; text-transform:uppercase; }
      h1 { margin:12px 0 14px; font-size:clamp(2.4rem,7vw,5.8rem); line-height:.96; letter-spacing:-.055em; overflow-wrap:anywhere; }
      .desc { max-width:680px; color:#bdb4cc; font-size:clamp(1rem,2vw,1.2rem); line-height:1.65; white-space:pre-wrap; }
      .meta { display:flex; gap:16px; flex-wrap:wrap; margin-top:22px; color:var(--muted); font:12px var(--mono); }
      .notice { margin:30px 0; padding:14px 16px; border:1px solid var(--edge); border-left:3px solid var(--purple); border-radius:8px; background:rgba(18,13,30,.72); color:#bdb4cc; font:13px/1.5 var(--mono); }
      .grid { display:grid; grid-template-columns:repeat(12,1fr); gap:18px; }
      figure { grid-column:span 6; margin:0; background:var(--panel); border:1px solid var(--edge); border-radius:12px; overflow:hidden; box-shadow:0 18px 55px rgba(0,0,0,.24); }
      .media { min-height:260px; aspect-ratio:16/10; background:#09070f; display:grid; place-items:center; overflow:hidden; }
      img,video { width:100%; height:100%; object-fit:contain; display:block; }
      .fallback { padding:30px; text-align:center; color:var(--muted); font:13px/1.6 var(--mono); }
      .fallback strong { display:block; color:var(--danger); margin-bottom:8px; }
      .fallback a { color:var(--cyan); overflow-wrap:anywhere; }
      figcaption { padding:15px 17px 17px; border-top:1px solid var(--edge); }
      .filename { color:var(--fg); font:600 13px var(--mono); overflow-wrap:anywhere; }
      .original { display:inline-block; margin-top:10px; color:var(--cyan); font:12px var(--mono); }
      .caption { margin-top:8px; color:#afa6bf; font-size:14px; line-height:1.5; white-space:pre-wrap; }
      .empty,.error { padding:70px 24px; border:1px dashed var(--edge); border-radius:12px; text-align:center; background:rgba(18,13,30,.5); }
      .empty code,.error code { color:var(--purple); font-family:var(--mono); }
      footer { margin-top:44px; color:#71687f; font:12px/1.6 var(--mono); }
      @media (max-width:760px) { .shell{width:min(100% - 22px,1180px);padding-top:22px} nav{margin-bottom:44px} figure{grid-column:1/-1}.media{min-height:190px} }
    </style>
  </head>
  <body>
    <main class="shell">
      <nav><a class="brand" href="/"><span>↑</span> uploads.sh</a><span class="public">public gallery</span></nav>
      {gallery ? (
        <>
          <header>
            <div class="eyebrow">Media collection</div>
            <h1>{gallery.title}</h1>
            {gallery.description && <div class="desc">{gallery.description}</div>}
            <div class="meta"><span>{gallery.items.length} {gallery.items.length === 1 ? "item" : "items"}</span><span>updated {new Date(gallery.updatedAt).toLocaleDateString("en-US", { year:"numeric", month:"short", day:"numeric" })}</span></div>
          </header>
          <aside class="notice">Anyone with this link can view and enumerate this gallery. Do not share sensitive media.</aside>
          {gallery.items.length === 0 ? <section class="empty"><code>gallery.empty</code><p>This gallery is ready, but no media has been added yet.</p></section> : (
            <section class="grid">
              {gallery.items.map((item) => (
                <figure>
                  <div class="media">
                    {kind(item) === "image" && <img src={item.url!} alt={item.altText ?? item.caption ?? item.filename} loading="lazy" decoding="async" />}
                    {kind(item) === "video" && <video src={item.url!} controls playsinline preload="metadata" aria-describedby={`caption-${item.id}`}>Your browser cannot play this video.</video>}
                    {kind(item) === "file" && <div class="fallback"><strong>Preview unavailable</strong><a href={item.url!} rel="noopener noreferrer">Open {item.filename}</a></div>}
                    {kind(item) === "unsupported" && <div class="fallback"><strong>Unsupported media type</strong><span>This item cannot be opened inline.</span></div>}
                    {kind(item) === "missing" && <div class="fallback"><strong>Removed or expired</strong><span>This item remains in the gallery to preserve its place.</span></div>}
                  </div>
                  <figcaption id={`caption-${item.id}`}><div class="filename">{item.filename}</div>{item.caption && <div class="caption">{item.caption}</div>}{item.status === "available" && kind(item) !== "unsupported" && <a class="original" href={item.url!} rel="noopener noreferrer">Open original</a>}</figcaption>
                </figure>
              ))}
            </section>
          )}
          <footer>External work-item references are not displayed publicly. · gallery {gallery.id}</footer>
        </>
      ) : (
        <section class="error"><code>{result.status === "not_found" ? "gallery.not_found" : "gallery.unavailable"}</code><h1>{result.status === "not_found" ? "Gallery not found" : "Gallery temporarily unavailable"}</h1><p>{result.status === "not_found" ? "Check the link or ask the gallery owner for a current URL." : "The gallery service could not be reached. Please try again shortly."}</p></section>
      )}
    </main>
  </body>
</html>
