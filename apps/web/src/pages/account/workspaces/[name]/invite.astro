---
/**
 * Legacy path — the invite UI now lives on the workspace people tab
 * (`[name]/people.astro`). Redirect old `/invite` deep links there.
 */
import { isBrowseWorkspace } from "../../../../lib/workspace-browse-url";
export const prerender = false;
const nameParam = Astro.params.name ?? "";
const workspace = isBrowseWorkspace(nameParam) ? nameParam : "";
if (!workspace) return Astro.redirect("/account/workspaces");
return Astro.redirect(`/account/workspaces/${encodeURIComponent(workspace)}/people`, 301);
---
