---
/**
 * Official GitHub mark (viewBox 0 0 24 24). Same path as `lib/brand-icons`
 * and releases `AccountIcon` — not a Lucide brand icon (Lucide dropped them).
 */
import { GITHUB_MARK_PATH } from "../lib/brand-icons";

interface Props {
  size?: number;
  class?: string;
}
const { size = 16, class: className } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 24 24"
  width={size}
  height={size}
  aria-hidden="true"
  focusable="false"
>
  <path fill="currentColor" d={GITHUB_MARK_PATH}></path>
</svg>
