{
  "name": "uploads",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run dev:api",
    "dev:api": "pnpm --filter @uploads/api dev",
    "dev:web": "pnpm --filter @uploads/web dev",
    "build": "pnpm --filter @uploads/web build",
    "deploy": "pnpm run deploy:api && pnpm run deploy:web",
    "deploy:api": "pnpm --filter @uploads/api run deploy",
    "deploy:web": "pnpm --filter @uploads/web run deploy",
    "upload:api": "pnpm --filter @uploads/api exec wrangler versions upload",
    "upload:web": "pnpm --filter @uploads/web run build && pnpm --filter @uploads/web exec wrangler versions upload",
    "types": "pnpm --filter @uploads/api types",
    "typecheck": "pnpm -r typecheck",
    "workspace:add": "pnpm --filter @uploads/api run workspace:add"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.10.0"
}
