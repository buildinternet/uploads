{
  "description": "Advisory reminder to stage screenshots on uploads.sh before opening a PR that touches UI files.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uploads hook pre-pr-screenshot",
            "timeout": 15,
            "statusMessage": "Checking staged screenshots"
          }
        ]
      }
    ]
  }
}
